{
  "name": "garlic-finance-desktop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tauri:dev": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH%&& tauri dev",
    "build": "tsc -b && vite build",
    "sidecar:build": "python ../../services/importer/build_sidecar.py",
    "tauri:build": "npm run sidecar:build && set PATH=%USERPROFILE%\\.cargo\\bin;%PATH%&& tauri build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "smoke:e2e:v16": "node ./scripts/smoke-v16-e2e.mjs",
    "security:check:rc": "node ./scripts/security-rc-check.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2.8.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.56.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
